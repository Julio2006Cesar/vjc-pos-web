---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Cotizar mi Software',
        href: 'https://wa.me/527298619743',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Ver Sistemas', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Tecnología y Automatización para <span class="text-accent dark:text-white highlight">Negocios y Empresas</span> en Hidalgo
    </Fragment>

    <Fragment slot="subtitle">
      Puntos de Venta para abarrotes, restaurantes y barberías; control biométrico para gimnasios y <span class="font-semibold">desarrollo de software a la medida</span>. Sin rentas mensuales y con soporte técnico local.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="El sello VJC:" description="No rentas el software, lo adquieres. Soluciones de uso rudo creadas por desarrolladores de la región." />
  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Nuestras Soluciones"
    title="Un ecosistema de software diseñado para tu industria"
    subtitle="Elige el sistema optimizado para tu giro comercial o pídenos un desarrollo programado a tu medida."
    items={[
      {
        title: 'POS: Abarrotes y Retail',
        description:
          'Soporta miles de productos. Escaneo ultrarrápido por código de barras, control de stock, alertas de inventario bajo y corte de caja a prueba de robos.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'POS: Restaurantes y Bares',
        description:
          'Control de mesas abiertas, comandas impresas directo en cocina/barra, división de cuentas, gestión de propinas y merma de ingredientes.',
        icon: 'tabler:coffee',
      },
      {
        title: 'POS: Barberías y Estéticas',
        description:
          'Registro de servicios, agenda de citas, base de datos de clientes frecuentes y cálculo automático de comisiones por barbero o estilista.',
        icon: 'tabler:scissors',
      },
      {
        title: 'Sistema GYM (Acceso Biométrico)',
        description:
          'Control de socios mediante huella digital o reconocimiento facial. Alertas de pago, bloqueo de morosos e historial de asistencias.',
        icon: 'tabler:fingerprint',
      },
      {
        title: 'Fábrica de Software a la Medida',
        description:
          '¿Tu empresa tiene un proceso administrativo complejo? Diseñamos bases de datos, software a medida y automatizaciones desde cero.',
        icon: 'tabler:code',
      },
      {
        title: 'Licencia Vitalicia + Soporte Local',
        description:
          'Sin pagar mensualidades forzosas. Vamos a tu local en Sahagún y todo Hidalgo a instalar el sistema y capacitar a tu personal presencialmente.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Control de Accesos Inteligente"
    title="Sistema GYM: Automatización y Seguridad Biométrica"
    items={[
      {
        title: 'Acceso por Huella o Rostro',
        description:
          'Integración nativa con lectores biométricos y reconocimiento facial para validar la entrada de socios en menos de un segundo.',
      },
      {
        title: 'Bloqueo Automático de Morosos',
        description:
          'El sistema detecta instantáneamente si la membresía de un usuario ha vencido, denegando el paso en el acceso físico de forma automatizada.',
      },
      {
        title: 'Métricas e Historial de Asistencias',
        description:
          'Genera reportes detallados y gráficas de flujo de usuarios para conocer las horas pico de tu club y optimizar tus entrenadores.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Control de acceso en Gimnasio con Software Biométrico',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Moderniza la administración de tu club</h3>
      Elimina por completo las credenciales impresas falsificables y el acceso no autorizado con tecnología de validación de identidad en tiempo real.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Hardware 100% Compatible',
        description: `Conecta lectores de código de barras, impresoras térmicas de tickets, cajones de dinero automáticos y básculas electrónicas de forma totalmente nativa.`,
      },
      {
        title: 'Reportes de Ventas y Productos Estrella',
        description:
          'Monitorea tus márgenes de ganancia exactos, analiza cuáles son tus productos más vendidos y detecta fugas de inventario al instante.',
      },
      {
        title: 'Usuarios, Roles y Permisos Seguros',
        description:
          'Protege tu información administrativa creando perfiles independientes para cajeros, empleados y supervisores con restricciones de cancelaciones.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556742044-3c52d6e88c62?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Punto de Venta comercial en mostrador',
    }}
  >
    <Fragment slot="content">Tecnología de uso rudo para el comercio local</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Desarrollo a la Medida de tus Procesos',
        description:
          'No adaptes tu empresa a un programa genérico; nosotros construimos la base de datos y la interfaz exactamente como tu operación lo requiere.',
      },
      {
        title: 'Automatización de Tareas Repetitivas',
        description:
          'Eliminamos cuellos de botella administrativos conectando sucursales, generando reportes financieros en un clic y optimizando flujos de trabajo.',
      },
      {
        title: 'Tecnología Moderna, Segura y Escalable',
        description:
          'Desarrollamos con lenguajes de última generación. Tu infraestructura estará preparada para crecer y soportar grandes volúmenes de información.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Código de programación y desarrollo de software',
    }}
  >
    <Fragment slot="content">Fábrica de Software y Automatización</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Tu nuevo sistema implementado y operando en 3 pasos simples:"
    items={[
      {
        title: 'Paso 1: <span class="font-medium">Solicita tu Cotización o Demo</span>',
        description:
          'Contáctanos vía WhatsApp. Platicamos sobre las necesidades operativas de tu negocio y te mostramos el software funcionando en tiempo real.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Paso 2: <span class="font-medium">Instalación Local y Hardware</span>',
        description:
          'Acudimos presencialmente a tu establecimiento en Ciudad Sahagún o cualquier municipio de Hidalgo para instalar el sistema y configurar tus periféricos.',
        icon: 'tabler:settings',
      },
      {
        title: 'Paso 3: <span class="font-medium">Capacitación Exprés</span>',
        description:
          'Entrenamos a tus cajeros, recepcionistas o administradores en menos de 45 minutos. La interfaz es tan intuitiva que la dominarán el mismo día.',
        icon: 'tabler:users',
      },
      {
        title: '¡Listo para cobrar y administrar!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1000&q=80',
      alt: 'Instalación y configuración de VJC POS en sitio',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Periféricos y Hardware 100% Compatibles"
    subtitle="Conecta los equipos de tu mostrador por USB o Bluetooth sin configuraciones complejas"
    tagline="Escalabilidad Garantizada"
    items={[
      {
        title: 'Impresoras Térmicas',
        description: 'Impresión de tickets de venta, cortes de caja y comandas directas a cocina por USB, Bluetooth o Red local.',
        icon: 'tabler:printer',
      },
      {
        title: 'Lectores de Código de Barras',
        description: 'Escaneo instantáneo con pistolas láser u omnidireccionales para agilizar el cobro en mini-supers y retail.',
        icon: 'tabler:barcode',
      },
      {
        title: 'Cajones de Dinero',
        description: 'Apertura automática de la gaveta al registrar un pago en efectivo o al autorizar un retiro de valores.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Computadoras y Laptops',
        description: 'Funciona de forma fluida en cualquier equipo con Windows 10 u 11. No requieres comprar terminales costosas.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Bases de Datos Locales',
        description: 'Respaldos automáticos en tu propio disco duro. Tu información está protegida y no depende de servidores externos.',
        icon: 'tabler:database',
      },
      {
        title: 'Lectores Biométricos',
        description: 'Acceso seguro de empleados o socios de gimnasios mediante huella digital para autorizar entradas o descuentos.',
        icon: 'tabler:fingerprint',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>


  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Preguntas Frecuentes"
    subtitle="Resolvemos las dudas más comunes de los dueños de negocios en Hidalgo"
    tagline="Dudas Resueltas"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Tengo que pagar una renta mensual o anual por el software?',
        description:
          '¡No! A diferencia de otros sistemas que te amarran a una mensualidad de por vida, en VJC realizas un pago único por tu licencia y el software es tuyo para siempre.',
      },
      {
        title: '¿Qué pasa si cambio de computadora o se daña mi equipo?',
        description:
          'Tu inversión está protegida. Si renuevas tu mostrador o tu máquina sufre un percance, nosotros nos encargamos de respaldar tu información y reactivar tu licencia en el nuevo equipo.',
      },
      {
        title: '¿Qué computadora o laptop necesito para que funcione?',
        description:
          'Nuestros sistemas están optimizados para ser sumamente ligeros. Funcionan de forma fluida en cualquier equipo con Windows (10 u 11) que ya tengas a la mano en tu negocio.',
      },
      {
        title: '¿Ofrecen soporte técnico si tengo algún problema?',
        description:
          'Sí, contamos con soporte directo vía WhatsApp y asistencia presencial en Ciudad Sahagún y municipios cercanos. Si requieres apoyo, hablas directamente con los ingenieros que lo desarrollaron.',
      },
      {
        title: '¿Puedo importar mi lista de precios y productos desde Excel?',
        description:
          '¡Claro! Para que no tengas que capturar tu inventario a mano uno por uno, podemos hacer una carga masiva de todos tus productos, códigos de barras y existencias desde una hoja de cálculo.',
      },
      {
        title: '¿Pueden hacerle modificaciones a la medida de mi empresa?',
        description:
          'Sí. Al ser los desarrolladores directos del código, podemos programar reportes específicos, módulos especiales o conectar el sistema a tus necesidades particulares.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Cobro por Licencia', amount: 'Único' },
      { title: 'Soporte Presencial', amount: 'Hidalgo' },
      { title: 'Compatibilidad', amount: '100%' },
      { title: 'Rentas Mensuales', amount: '$0' },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Cotizar mi Sistema por WhatsApp',
        href: 'https://wa.me/527298619743',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Toma el control absoluto de tu negocio hoy mismo
    </Fragment>

    <Fragment slot="subtitle">
      No dejes que el desorden en las cuentas, la fuga de inventario o los procesos lentos sigan frenando tus ganancias. <br class="hidden md:inline" />Escríbenos y platiquemos sobre la solución exacta que tu empresa necesita.
    </Fragment>
  </CallToAction>
</Layout>