---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// <-- AQUÍ CONFIGURÉ EL TEXTO EXACTO DE TU PESTAÑA
const metadata = {
  title: 'VJC S.A. de C.V.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Cotizar mi Software',
        href: 'https://wa.me/527298619743',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Ver Sistemas', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Tecnología y Automatización para <span class="text-accent dark:text-white highlight">Negocios y Empresas</span> en Hidalgo
    </Fragment>

    <Fragment slot="subtitle">
      Puntos de Venta para abarrotes, restaurantes y barberías; control biométrico para gimnasios y <span class="font-semibold">desarrollo de software a la medida</span>. Sin rentas mensuales y con soporte técnico local.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="El sello VJC:" description="No rentas el software, lo adquieres. Soluciones de uso rudo creadas por desarrolladores de la región." />
  
  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Nuestras Soluciones"
    title="Un ecosistema de software diseñado para tu industria"
    subtitle="Elige el sistema optimizado para tu giro comercial o pídenos un desarrollo programado a tu medida."
    items={[
      {
        title: 'POS: Abarrotes y Retail',
        description: 'Soporta miles de productos. Escaneo ultrarrápido por código de barras, control de stock y corte de caja.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'POS: Restaurantes y Bares',
        description: 'Control de mesas abiertas, comandas impresas directo en cocina/barra y división de cuentas.',
        icon: 'tabler:coffee',
      },
      {
        title: 'POS: Barberías y Estéticas',
        description: 'Registro de servicios, agenda de citas, clientes frecuentes y cálculo de comisiones.',
        icon: 'tabler:scissors',
      },
      {
        title: 'Sistema GYM (Acceso Biométrico)',
        description: 'Control de socios mediante huella digital o rostro. Alertas de pago y bloqueo de morosos.',
        icon: 'tabler:fingerprint',
      },
      {
        title: 'Fábrica de Software a la Medida',
        description: 'Diseñamos bases de datos, software a medida y automatizaciones desde cero.',
        icon: 'tabler:code',
      },
      {
        title: 'Licencia Vitalicia + Soporte Local',
        description: 'Sin pagar mensualidades. Vamos a tu local en Sahagún y todo Hidalgo a instalarlo.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- ==================== SISTEMA 1: ABARROTES ==================== -->
  <Content
    id="abarrotes"
    isAfterContent
    tagline="Punto de Venta Mostrador"
    title="POS Abarrotes y Retail: Cobro Ultrarrápido"
    items={[
      {
        title: 'Escaneo Continuo sin Pausas',
        description: 'Compatible con cualquier lector de código de barras. Pasa los productos a máxima velocidad para que la fila de tu mostrador no se detenga.',
      },
      {
        title: 'Alertas de Inventario Crítico',
        description: 'El sistema te notifica automáticamente cuando un producto está a punto de agotarse para que resurtas a tiempo y no pierdas ventas.',
      },
      {
        title: 'Corte de Caja Blindado',
        description: 'Desglosa ingresos en efectivo, tarjeta y transferencias. Registra entradas/salidas de dinero y detecta faltantes al centavo.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1578916171728-46686eac8d58?q=80&w=1000&auto=format&fit=crop',
      alt: 'Punto de venta para Mini supers y Abarrotes',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Diseñado para el tráfico pesado</h3>
      Olvídate de las cuentas a mano y el robo hormiga. Administra miles de productos con sus márgenes de ganancia exactos.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- ==================== SISTEMA 2: RESTAURANTES ==================== -->
  <Content
    id="restaurantes"
    isReversed
    isAfterContent
    tagline="Gastronomía y Hostelería"
    title="POS Restaurantes: De la Mesa a la Cocina"
    items={[
      {
        title: 'Comandas Impresas en Cocina o Barra',
        description: 'Al capturar el pedido en el mostrador, el ticket sale de forma instantánea en la zona de preparación para agilizar a tus chefs.',
      },
      {
        title: 'Mapa de Mesas en Tiempo Real',
        description: 'Controla visualmente qué mesas están libres, cuáles están esperando su orden y cuánto tiempo llevan consumiendo.',
      },
      {
        title: 'Cuentas Divididas y Propinas',
        description: 'Separa la cuenta por persona o por platillo en un solo clic, calculando los porcentajes de propina de forma automática.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=1000&auto=format&fit=crop',
      alt: 'Punto de venta para Restaurantes, Cafeterías y Bares',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Máxima coordinación con tus meseros</h3>
      Elimina los errores de captura en los pedidos y ten un control estricto de los insumos que salen de tu cocina.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- ==================== SISTEMA 3: BARBERÍAS ==================== -->
  <Content
    id="barberias"
    isAfterContent
    tagline="Barberías y Salones de Belleza"
    title="POS Barberías: Comisiones y Agenda VIP"
    items={[
      {
        title: 'Cálculo de Comisiones Exacto',
        description: 'Asigna el porcentaje de ganancia de cada barbero o estilista. El software calcula su pago del día o la semana automáticamente.',
      },
      {
        title: 'Base de Datos de Clientes Frecuentes',
        description: 'Guarda el perfil de cada cliente con su estilo de corte, barba o tinte favorito para ofrecerle una experiencia de lujo.',
      },
      {
        title: 'Control de Vitrina y Productos',
        description: 'Administra en la misma caja la venta de insumos como ceras, geles, tónicos, minoxidil y tratamientos capilares.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=1000&auto=format&fit=crop',
      alt: 'Punto de venta para Barberías y Estéticas',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Profesionaliza tu Barber Shop</h3>
      Proyecta absoluta seriedad en tu mostrador y ten cuentas claras y transparentes con tu equipo de trabajo.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- ==================== SISTEMA 4: GIMNASIOS ==================== -->
  <Content
    id="gym"
    isReversed
    isAfterContent
    tagline="Control de Accesos Inteligente"
    title="Sistema GYM: Seguridad Biométrica"
    items={[
      {
        title: 'Acceso por Huella Digital o Rostro',
        description: 'Integración de uso rudo con torniquetes y lectores biométricos para validar la entrada de tus socios en una fracción de segundo.',
      },
      {
        title: 'Bloqueo Inmediato de Morosos',
        description: 'El sistema detecta al instante si la mensualidad de un socio ha vencido, cerrándole el paso en la puerta automáticamente.',
      },
      {
        title: 'Gráficas de Asistencia y Horas Pico',
        description: 'Mide el flujo de usuarios por horario para saber en qué momentos necesitas más personal o entrenadores en piso.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Control de acceso en Gimnasio con Software Biométrico',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Protege los ingresos de tu Club</h3>
      Ponle fin a las credenciales prestadas y asegura que toda persona que entre a entrenar tenga su membresía pagada.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="steps"
    title="Instalación y Configuración del Sistema"
    items={[
      {
        title: 'Paso 1: <span class="font-medium">Solicita tu Cotización o Demo</span>',
        description: 'Contáctanos vía WhatsApp. Platicamos sobre las necesidades operativas de tu negocio y te mostramos el software funcionando en tiempo real.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Paso 2: <span class="font-medium">Instalación Local y Hardware</span>',
        description: 'Acudimos presencialmente a tu establecimiento en Ciudad Sahagún o cualquier municipio de Hidalgo para instalar el sistema y configurar tus periféricos.',
        icon: 'tabler:settings',
      },
      {
        title: 'Paso 3: <span class="font-medium">Capacitación Exprés</span>',
        description: 'Entrenamos a tus cajeros, recepcionistas o administradores en menos de 45 minutos. La interfaz es tan intuitiva que la dominarán el mismo día.',
        icon: 'tabler:users',
      },
      {
        title: '¡Listo para cobrar y administrar!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1000&q=80',
      alt: 'Instalación y configuración de VJC POS en sitio',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Periféricos y Hardware 100% Compatibles"
    subtitle="Conecta los equipos de tu mostrador por USB o Bluetooth sin configuraciones complejas"
    tagline="Escalabilidad Garantizada"
    items={[
      {
        title: 'Impresoras Térmicas',
        description: 'Impresión de tickets de venta, cortes de caja y comandas directas a cocina por USB, Bluetooth o Red local.',
        icon: 'tabler:printer',
      },
      {
        title: 'Lectores de Código de Barras',
        description: 'Escaneo instantáneo con pistolas láser u omnidireccionales para agilizar el cobro en mini-supers y retail.',
        icon: 'tabler:barcode',
      },
      {
        title: 'Cajones de Dinero',
        description: 'Apertura automática de la gaveta al registrar un pago en efectivo o al autorizar un retiro de valores.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Computadoras y Laptops',
        description: 'Funciona de forma fluida en cualquier equipo con Windows 10 u 11. No requieres comprar terminales costosas.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Bases de Datos Locales',
        description: 'Respaldos automáticos en tu propio disco duro. Tu información está protegida y no depende de servidores externos.',
        icon: 'tabler:database',
      },
      {
        title: 'Lectores Biométricos',
        description: 'Acceso seguro de empleados o socios de gimnasios mediante huella digital para autorizar entradas o descuentos.',
        icon: 'tabler:fingerprint',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faqs"
    title="Preguntas Frecuentes"
    subtitle="Resolvemos las dudas más comunes de los dueños de negocios en Hidalgo"
    tagline="Dudas Resueltas"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Tengo que pagar una renta mensual o anual por el software?',
        description: '¡No! A diferencia de otros sistemas que te amarran a una mensualidad de por vida, en VJC realizas un pago único por tu licencia y el software es tuyo para siempre.',
      },
      {
        title: '¿Qué pasa si cambio de computadora o se daña mi equipo?',
        description: 'Tu inversión está protegida. Si renuevas tu mostrador o tu máquina sufre un percance, nosotros nos encargamos de respaldar tu información y reactivar tu licencia en el nuevo equipo.',
      },
      {
        title: '¿Qué computadora o laptop necesito para que funcione?',
        description: 'Nuestros sistemas están optimizados para ser sumamente ligeros. Funcionan de forma fluida en cualquier equipo con Windows (10 u 11) que ya tengas a la mano en tu negocio.',
      },
      {
        title: '¿Ofrecen soporte técnico si tengo algún problema?',
        description: 'Sí, contamos con soporte directo vía WhatsApp y asistencia presencial en Ciudad Sahagún y municipios cercanos. Si requieres apoyo, hablas directamente con los ingenieros que lo desarrollaron.',
      },
      {
        title: '¿Puedo importar mi lista de precios y productos desde Excel?',
        description: '¡Claro! Para que no tengas que capturar tu inventario a mano uno por uno, podemos hacer una carga masiva de todos tus productos, códigos de barras y existencias desde una hoja de cálculo.',
      },
      {
        title: '¿Pueden hacerle modificaciones a la medida de mi empresa?',
        description: 'Sí. Al ser los desarrolladores directos del código, podemos programar reportes específicos, módulos especiales o conectar el sistema a tus necesidades particulares.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Cobro por Licencia', amount: 'Único' },
      { title: 'Soporte Presencial', amount: 'Hidalgo' },
      { title: 'Compatibilidad', amount: '100%' },
      { title: 'Rentas Mensuales', amount: '$0' },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Cotizar mi Sistema por WhatsApp',
        href: 'https://wa.me/527298619743',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Toma el control absoluto de tu negocio hoy mismo
    </Fragment>

    <Fragment slot="subtitle">
      No dejes que el desorden en las cuentas, la fuga de inventario o los procesos lentos sigan frenando tus ganancias. <br class="hidden md:inline" />Escríbenos y platiquemos sobre la solución exacta que tu empresa necesita.
    </Fragment>
  </CallToAction>
</Layout>